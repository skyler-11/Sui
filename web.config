<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="ReverseProxyToStreamlit" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:4444/{R:1}" />
        </rule>
      </rules>

      <!--
        SEC [QA / Qualys WAS]: Force Secure + SameSite on every Set-Cookie
        emitted by the Streamlit upstream. Streamlit doesn't expose a knob
        for these flags, so the proxy injects them on the way out.

          Secure       — cookie only sent over HTTPS (HSTS-aligned).
          SameSite=Lax — blocks third-party cross-site cookie use; Lax
                         (not Strict) preserves the OAuth redirect flow,
                         which is a top-level GET navigation.

        The pattern guard `(?!.*; *Secure)` / `(?!.*; *SameSite)` keeps the
        rule idempotent — if Streamlit ever starts emitting these flags
        natively we won't double-stamp them.
      -->
      <outboundRules>
        <rule name="AddSecureToCookies" preCondition="UnsecuredCookie">
          <match serverVariable="RESPONSE_Set_Cookie" pattern="(.*)" />
          <action type="Rewrite" value="{R:1}; Secure" />
        </rule>
        <rule name="AddSameSiteToCookies" preCondition="NoSameSiteCookie">
          <match serverVariable="RESPONSE_Set_Cookie" pattern="(.*)" />
          <action type="Rewrite" value="{R:1}; SameSite=Lax" />
        </rule>
        <preConditions>
          <preCondition name="UnsecuredCookie">
            <add input="{RESPONSE_Set_Cookie}" pattern="." />
            <add input="{RESPONSE_Set_Cookie}" pattern="; *Secure" negate="true" />
          </preCondition>
          <preCondition name="NoSameSiteCookie">
            <add input="{RESPONSE_Set_Cookie}" pattern="." />
            <add input="{RESPONSE_Set_Cookie}" pattern="; *SameSite=" negate="true" />
          </preCondition>
        </preConditions>
      </outboundRules>
    </rewrite>

    <security>
      <!--
        SEC [QA / Qualys WAS]: HTTP method allowlist.
          GET / POST / HEAD : core Streamlit traffic (page, websocket upgrade, health).
          PUT               : st.file_uploader uploads to /_stcore/upload_file/...
                              (Streamlit >=1.30 uses PUT, not POST). Removing this
                              caused AxiosError 404 in the uploader (IIS returns
                              404.6 Verb Denied for filtered verbs).
          DELETE            : st.file_uploader "remove file" (X button) issues
                              DELETE to the same /_stcore/upload_file/... path.
          TRACE             : Qualys finding "HTTP TRACE Method Enabled" — refused.
          OPTIONS / CONNECT : not used; refused to keep attack surface minimal.
        allowUnlisted="false" makes the list a strict allowlist.
      -->
      <requestFiltering removeServerHeader="true">
        <verbs allowUnlisted="false">
          <add verb="GET"    allowed="true" />
          <add verb="POST"   allowed="true" />
          <add verb="HEAD"   allowed="true" />
          <add verb="PUT"    allowed="true" />
          <add verb="DELETE" allowed="true" />
        </verbs>
      </requestFiltering>
    </security>

    <httpProtocol>
      <customHeaders>
        <!--
          SEC [QA / Qualys WAS]: Strip information-disclosure headers that
          IIS / ASP.NET emit by default. `removeServerHeader` (in <security>)
          handles the Server: header. These cover the rest:
            X-Powered-By        — "ASP.NET"
            X-AspNet-Version    — exact .NET version
            X-AspNetMvc-Version — exact MVC version
        -->
        <remove name="X-Powered-By" />
        <remove name="X-AspNet-Version" />
        <remove name="X-AspNetMvc-Version" />

        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options"        value="SAMEORIGIN" />
        <add name="Referrer-Policy"        value="strict-origin-when-cross-origin" />
        <add name="Permissions-Policy"     value="camera=(), microphone=(), geolocation=()" />

        <!--
          SEC [QA]: Strict-Transport-Security (HSTS)
          Instructs browsers to always use HTTPS for this origin for the next
          365 days. includeSubDomains covers any subdomains served from the
          same IIS instance. Remove includeSubDomains if your subdomains are
          not all HTTPS-capable. Do NOT enable preload unless you are certain
          this domain will permanently serve HTTPS — preload is irrevocable
          for the preload list lifetime.

          IMPORTANT: Only activate once HTTPS is fully configured on IIS.
          Enabling HSTS on an HTTP server causes the site to become
          unreachable from browsers that have already cached the header.
        -->
        <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains" />

        <!--
          SEC [QA]: X-XSS-Protection
          Legacy header — modern browsers (Chrome 78+, Firefox, Edge) have
          removed the XSS auditor and ignore this header. Included for
          compliance scanner requirements (OWASP ZAP, Nessus, corporate
          security baselines) that still flag its absence as a finding.
        -->
        <add name="X-XSS-Protection" value="1; mode=block" />

        <!--
          SEC [QA / Qualys WAS]: Browser caching of authenticated pages.
          Without no-store, browsers (and shared corporate proxies) may
          retain rendered HTML containing schedule data / user identity in
          the back/forward cache. no-store + no-cache + must-revalidate +
          private is the belt-and-braces combo every scanner accepts.
          Pragma: no-cache covers HTTP/1.0 intermediaries.
        -->
        <add name="Cache-Control" value="no-store, no-cache, must-revalidate, private" />
        <add name="Pragma"        value="no-cache" />

        <!--
          SEC [QA / Qualys WAS]: Cross-origin isolation headers.
            COOP=same-origin       — denies cross-origin window references
                                     (mitigates Spectre-class side channels
                                     and tab-nabbing of an opener).
            CORP=same-origin       — prevents other origins from embedding
                                     this app's resources.
          We deliberately DO NOT set COEP=require-corp — it would block the
          Keycloak login iframe (different origin) and any third-party fonts
          that aren't CORS-stamped, which would break the auth flow.
        -->
        <add name="Cross-Origin-Opener-Policy"   value="same-origin" />
        <add name="Cross-Origin-Resource-Policy" value="same-origin" />

        <!--
          FIX [Keycloak login - CSP]:
          The PKCE flow involves two network actors:
            1. Popup → Keycloak server (auth endpoint): needs frame-src + connect-src
               pointing at the KC host.
            2. KC popup redirect → app's redirect_uri: the KC popup navigates to
               the app's public URL to deliver the auth code.  The app page then
               POSTs to KC /token from 'self'.  If 'self' is absent from
               connect-src the /token POST is CSP-blocked.

          Previous connect-src only listed the KC host.  'self' was missing,
          which caused the /token POST (originating from the app's own origin)
          to be blocked by the browser's CSP engine.

          ws: and wss: are retained for Streamlit's WebSocket connection.

          frame-src already includes 'self' (required for the KC redirect iframe)
          and the KC host (required for the KC login popup origin checks) — no
          change needed there.

          ACCEPTED RISK [QA / Qualys WAS]: 'unsafe-inline' + 'unsafe-eval' on
          script-src and 'unsafe-inline' on style-src are a Streamlit hard
          requirement (its inline runtime + dynamic JSX/CSS injection won't
          work without them). Compensating controls:
            - All user-supplied text is HTML-escaped before render
              (modules/auth.py _redirect_browser, sidebar render in Main.py).
            - st.markdown(unsafe_allow_html=True) is only fed app-controlled
              strings or strings escaped at the boundary.
            - id_token claims are escaped before display.
            - showErrorDetails=false hides stack traces from the client.
        -->
        <add name="Content-Security-Policy"
             value="default-src 'self'; frame-ancestors 'self'; object-src 'none'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self' ws: wss: https://keycloak.cb.prod.e2c.int.automotive-wan.com/auth/; frame-src 'self' https://keycloak.cb.prod.e2c.int.automotive-wan.com/auth/;" />
      </customHeaders>
    </httpProtocol>

  </system.webServer>
</configuration>
